{
  "name": "indigo-snacks-server",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/run-prisma.mjs db push && node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate": "node scripts/run-prisma.mjs db push",
    "prisma:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "prisma:dev": "node scripts/run-prisma.mjs db push",
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "prisma": "^5.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
