generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  shortDescription String
  description      String
  baseImage        String?
  badge            String?
  isActive         Boolean          @default(true)
  sortOrder        Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  variants         ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id                    String                @id @default(cuid())
  productId             String
  sku                   String                @unique
  label                 String
  weightGrams           Int
  priceKopecks          Int
  compareAtPriceKopecks Int?
  description           String?
  image                 String?
  isAvailable           Boolean               @default(true)
  sortOrder             Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  product               Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]
  subscriptionRequests  SubscriptionRequest[]

  @@index([productId])
  @@map("product_variants")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  phone     String
  email     String?
  message   String
  consent   Boolean
  status    String     @default("NEW")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("leads")
}

model Order {
  id                   String             @id @default(cuid())
  orderNumber          String             @unique
  customerName         String
  phone                String
  email                String?
  city                 String
  address              String
  postalCode           String
  comment              String?
  subtotalKopecks      Int
  deliveryCostKopecks  Int
  totalKopecks         Int
  deliveryMethod       String
  deliveryQuoteLabel   String
  paymentMethod        String
  paymentStatus        String             @default("PENDING")
  paymentNote          String?
  status               String             @default("NEW")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  items                OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                String          @id @default(cuid())
  orderId           String
  variantId         String?
  sku               String
  productName       String
  variantLabel      String
  quantity          Int
  unitPriceKopecks  Int
  totalPriceKopecks Int
  createdAt         DateTime        @default(now())
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant           ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model SubscriptionRequest {
  id                   String                @id @default(cuid())
  name                 String
  phone                String
  email                String?
  address              String
  comment              String?
  quantity             Int
  frequency            String
  status               String                @default("NEW")
  variantId            String?
  variantLabelSnapshot String
  itemsJson            String                @default("[]")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  variant              ProductVariant?       @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@map("subscription_requests")
}
